{
  "name": "agentura",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build --filter=!@agentura/web",
    "test": "pnpm --filter @agentura/eval-runner test && pnpm --filter agentura test",
    "type-check": "turbo run type-check",
    "dev": "turbo run dev --parallel"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
