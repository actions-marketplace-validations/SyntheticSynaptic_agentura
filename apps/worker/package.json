{
  "name": "@agentura/worker",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --dir ../../packages/core run build && tsc --outDir dist",
    "start": "node dist/index.js",
    "type-check": "pnpm --dir ../../packages/core run build && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@agentura/core": "workspace:^",
    "@agentura/db": "workspace:^",
    "@agentura/eval-runner": "workspace:^",
    "@agentura/types": "workspace:^",
    "@octokit/app": "^16.1.2",
    "bullmq": "^5.70.1",
    "groq-sdk": "^0.37.0",
    "ioredis": "^5.9.3",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  }
}
