{
  "name": "agentura",
  "version": "0.2.2",
  "description": "Automated eval checks for AI agents on every PR",
  "bin": {
    "agentura": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts run",
    "build": "pnpm --dir ../core run build && tsup",
    "type-check": "pnpm --dir ../core run build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm run build && node --test --import tsx src/commands/run.test.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@agentura/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.0.0",
    "groq-sdk": "^0.37.0",
    "js-yaml": "^4.1.0",
    "open": "^8.4.2",
    "openai": "^6.33.0",
    "p-limit": "3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
