{
  "name": "@agentura/eval-runner",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm --dir ../types run build && tsc -p tsconfig.json",
    "type-check": "pnpm --dir ../types run build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm run build && node --test $(find dist -name '*.test.js')"
  },
  "dependencies": {
    "@agentura/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "groq-sdk": "^1.1.2",
    "openai": "^6.33.0",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
